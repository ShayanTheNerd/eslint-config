{
  "name": "@shayanthenerd/eslint-config",
  "version": "0.17.0",
  "license": "MIT",
  "description": "A modern, flexible ESLint configuration for enforcing best practices and maintaining a consistent coding style",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-flat-config",
    "eslint-config-vue",
    "eslint-config-typescript",
    "oxlint",
    "oxlint-config"
  ],
  "homepage": "https://eslintconfig.netlify.app",
  "bugs": {
    "email": "dev.shayan.zamani@gmail.com",
    "url": "https://github.com/ShayanTheNerd/eslint-config/issues/new?template=bug_report.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShayanTheNerd/eslint-config.git"
  },
  "funding": "https://buymeacoffee.com/shayanthenerd",
  "author": {
    "name": "Shayan Zamani",
    "email": "dev.shayan.zamani@gmail.com",
    "url": "https://github.com/ShayanTheNerd"
  },
  "type": "module",
  "imports": {
    "#configs/*": "./src/configs/*",
    "#helpers/*": "./src/helpers/*",
    "#rules/*": "./src/rules/*",
    "#types/*": "./src/types/*",
    "#utils/*": "./src/utils/*"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./oxlint": "./dist/oxlint.config.jsonc",
    "./package.json": "./package.json",
    "./prettier": "./dist/prettier.config.mjs",
    "./types/*": "./dist/types/*"
  },
  "types": "./dist/index.d.mts",
  "files": [
    "./dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build:package",
    "prepare": "pnpm git:gitmessage && simple-git-hooks && pnpm generate:types",
    "git:gitmessage": "git config --local commit.template \".gitmessage\"",
    "update:actions": "actions-up --yes",
    "check:spell": "pnpx cspell . --gitignore --exclude='pnpm-lock.yaml' --cache --cache-location='./node_modules/.cache/.cspellcache'",
    "inspect": "eslint-config-inspector",
    "build:inspector": "eslint-config-inspector build --config=./scripts/configs/eslint.config.reference.ts",
    "preview:inspector": "serve .eslint-config-inspector",
    "generate:types": "node ./scripts/generateEslintTypes.ts",
    "generate:docs": "node ./scripts/generateApiDocs.ts",
    "check:types": "tsc",
    "build:package": "tsdown",
    "watch:package": "tsdown --watch --publint=false",
    "check:exports": "attw --pack --profile=esm-only --exclude-entrypoints=./oxlint",
    "format": "prettier --write '**/*.{json,jsonc,yaml,yml}' --cache",
    "lint": "pnpm lint:oxlint && pnpm lint:eslint",
    "lint:ci": "pnpm lint:oxlint --format=github && pnpm lint:eslint",
    "lint:eslint": "eslint --fix --cache --cache-location=./node_modules/.cache/.eslintcache",
    "lint:oxlint": "oxlint --fix",
    "ci:validate": "pnpm generate:types && pnpm format && pnpm build:package && pnpm lint:ci && pnpm check:types && pnpm build:inspector && pnpm build:package && pnpm check:exports && pnpm generate:docs"
  },
  "simple-git-hooks": {
    "pre-commit": "./node_modules/.bin/nano-staged"
  },
  "nano-staged": {
    "**/*.{js,ts}": "pnpm lint",
    "**/*.{json,jsonc,yaml,yml}": "pnpm format",
    "eslint.config.ts": "pnpm lint",
    "package.json": "pnpm lint:eslint",
    "prettier.config.ts": "pnpm format"
  },
  "dependencies": {
    "@eslint/compat": "2.0.2",
    "@eslint/css": "0.14.1",
    "@eslint/markdown": "8.0.2",
    "@html-eslint/eslint-plugin": "0.57.1",
    "@stylistic/eslint-plugin": "5.9.0",
    "@vitest/eslint-plugin": "1.6.9",
    "astro-eslint-parser": "1.3.0",
    "defu": "6.1.4",
    "eslint-flat-config-utils": "3.0.1",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-astro": "1.6.0",
    "eslint-plugin-better-tailwindcss": "4.3.1",
    "eslint-plugin-cypress": "6.1.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-oxlint": "1.50.0",
    "eslint-plugin-package-json": "0.89.1",
    "eslint-plugin-perfectionist": "5.6.0",
    "eslint-plugin-playwright": "2.7.1",
    "eslint-plugin-promise": "7.2.1",
    "eslint-plugin-storybook": "10.2.13",
    "eslint-plugin-vue": "10.8.0",
    "eslint-plugin-vuejs-accessibility": "2.5.0",
    "eslint-plugin-zod": "3.2.0",
    "globals": "17.3.0",
    "local-pkg": "1.1.2",
    "tailwind-csstree": "0.1.4",
    "typescript-eslint": "8.56.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@eslint/config-inspector": "1.4.2",
    "@types/node": "25.3.2",
    "actions-up": "1.12.0",
    "eslint": "10.0.2",
    "eslint-typegen": "2.3.1",
    "nano-staged": "0.9.0",
    "oxlint": "1.50.0",
    "prettier": "3.8.1",
    "publint": "0.3.17",
    "serve": "14.2.5",
    "simple-git-hooks": "2.13.1",
    "ts-morph": "27.0.2",
    "tsdown": "0.20.3",
    "typescript": "6.0.3",
    "unplugin-unused": "0.5.7"
  },
  "peerDependencies": {
    "eslint": "^10.0.0",
    "oxlint": "^1.50.0"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || ^24.0.0 || ^26.0.0"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "^22.18.0 || ^24.0.0 || ^26.0.0",
      "onFail": "warn"
    },
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "error"
    }
  },
  "publishConfig": {
    "access": "public"
  }
}
